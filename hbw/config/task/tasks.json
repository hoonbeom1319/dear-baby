{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Prettier: Format Active File",
            "type": "shell",
            "command": "npx",
            "args": [
                "prettier",
                "--write",
                "${file}"
            ],
            "problemMatcher": [],
            "presentation": {
                "close": true,
                "showReuseMessage": false,
                "clear": true
            }
        },
        {
            "label": "🔀 Checkout",
            "type": "shell",
            "command": "git  branch --all | ForEach-Object { $_.Trim() } | fzf | ForEach-Object { git checkout $_ }",
            "problemMatcher": [],
            "presentation": {
                "close": true,
                "showReuseMessage": false,
                "clear": true
            }
        },
        {
